// Phase 5: DMA Cache Manager
// DMA 인식 캐싱 + 프리페치 버퍼 관리

pub mod dma_cache_manager;

pub use dma_cache_manager::{
    DMASize, CacheLine, CachePriority, DMACache,
    CacheStatistics, PrefetchBuffer,
};

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_cache_module_exports() {
        let cache = DMACache::new(1000000, 100000);
        let stats = cache.statistics();
        assert_eq!(stats.hit_count, 0);
    }
}
