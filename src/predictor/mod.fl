// Phase 4: Predictive Prefetching Module

pub mod l0nn_prefetcher;

pub use l0nn_prefetcher::{
    L0NN, NeuralWeights, Activation, AccessSequence,
    L0NNPrefetcher, PrefetchRecommendation, PrefetchStatistics,
};

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_predictor_module_exports() {
        let prefetcher = L0NNPrefetcher::new();
        let stats = prefetcher.statistics();
        assert_eq!(stats.total_accesses, 0);
    }
}
